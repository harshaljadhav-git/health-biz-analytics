{
    "name": "health-biz-backend",
    "version": "1.0.0",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "dev": "cross-env NODE_ENV=development tsx src/index.ts",
        "build": "tsup src/index.ts --format cjs --out-dir dist --minify",
        "start": "cross-env NODE_ENV=production node dist/index.cjs",
        "db:init": "tsx src/init-db.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "date-fns": "^3.6.0",
        "dotenv": "^17.3.1",
        "express": "^5.0.1",
        "express-session": "^1.18.1",
        "memorystore": "^1.6.7",
        "mssql": "^11.0.1",
        "zod": "^3.24.2",
        "zod-validation-error": "^3.4.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/express-session": "^1.18.0",
        "@types/node": "20.19.27",
        "@vitest/coverage-v8": "^4.0.18",
        "cross-env": "^7.0.3",
        "tsup": "^8.4.0",
        "tsx": "^4.20.5",
        "typescript": "5.6.3",
        "vitest": "^4.0.18"
    }
}
